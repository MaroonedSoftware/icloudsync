# Copy to .env and fill in. Used by docker-compose.yml.
#
# Only the encryption secret is required. User settings (Apple ID, photo layout,
# sync schedule) are configured in the web UI after first boot — they live in
# the database, not here.

# Secret used to derive the AES-256 key that encrypts the persisted session at
# rest (Argon2id). Use a long random string; changing it invalidates the saved
# session (forces a re-login). Generate one e.g. `openssl rand -hex 32`.
ICLOUD_ENCRYPTION_SECRET=change-me-to-a-long-random-secret

# Rotating file log — optional; sensible defaults apply if unset. The log
# captures uncaught exceptions and unhandled rejections, so a crash leaves a
# durable reason on disk. In Docker LOG_DIR is mounted on the `logs_data` volume.
#
# LOG_DIR is infra (where the files live) and is env-only. The other three are
# only the *boot fallback*: once the app is running, the enabled flag, level, and
# rotation limits are edited in the web UI (Settings → Logging) and stored in the
# database, which takes over. Change them there, not here, for a running app.
# LOG_DIR=/data/logs
# LOG_LEVEL=info          # error | warn | info | debug | trace
# LOG_MAX_SIZE_MB=5       # roll the active file over past this many MB
# LOG_MAX_FILES=5         # files to keep, including the active one
