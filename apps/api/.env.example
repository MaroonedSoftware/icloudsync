# Local dev env for `pnpm dev`. Copy to apps/api/.env (gitignored) and fill in.
# The dev script loads this automatically (node --env-file-if-exists=.env).
#
# Only secrets + infra live here. User settings (account, photo layout, sync
# schedule) live in the database and are set in the web UI / via PATCH /icloud/settings.

# Secret used to derive the AES-256 key that encrypts the persisted session at
# rest (required). Use a long random string; `openssl rand -hex 32`.
ICLOUD_ENCRYPTION_SECRET=change-me-to-a-long-random-secret

# Postgres for the synced photo mirror + pg-boss queue (required).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/icloudsync?sslmode=disable

# Optional overrides.
# PORT=3000
# ICLOUD_PHOTOS_DIR=./.dev-photos     # where backed-up photo files are written
# WEB_ROOT=../web/dist
# (The encrypted session lives in the database — no session directory needed.)
