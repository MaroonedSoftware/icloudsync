{
    "name": "@maroonedsoftware/icloudsync-api",
    "private": true,
    "type": "module",
    "main": "index.ts",
    "scripts": {
        "dev": "node --env-file-if-exists=.env --inspect --no-warnings --no-deprecation --import @swc-node/register/esm-register --enable-source-maps --watch --watch-preserve-output ./src/index.ts",
        "build": "tsc",
        "seed:dev": "node --no-warnings --no-deprecation --import @swc-node/register/esm-register ./src/dev/seed.run.ts",
        "build:data": "pnpm migrate:up && pnpm build:datatypes",
        "rebuild:data": "pnpm migrate:down:all && pnpm build:data",
        "build:contracts": "contractkit",
        "build:datatypes": "kysely-codegen",
        "migrate:up": "dbmate -d ./data/migrations up",
        "migrate:down": "dbmate -d ./data/migrations down",
        "migrate:down:all": "./scripts/rollbackall.sh",
        "migrate:create": "dbmate -d ./data/migrations new",
        "lint": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest run",
        "sync:run": "node --no-warnings --no-deprecation --import @swc-node/register/esm-register ./scripts/sync.run.ts"
    },
    "dependencies": {
        "@icloudsync/icloud": "workspace:*",
        "@koa/router": "^15.6.0",
        "@maroonedsoftware/appconfig": "^2.1.0",
        "@maroonedsoftware/encryption": "^0.5.2",
        "@maroonedsoftware/errors": "^1.7.0",
        "@maroonedsoftware/jobbroker": "^1.7.0",
        "@maroonedsoftware/koa": "^2.4.5",
        "@maroonedsoftware/kysely": "^0.7.0",
        "@maroonedsoftware/logger": "^1.1.1",
        "@maroonedsoftware/storage": "^0.3.0",
        "@maroonedsoftware/zod": "^0.4.2",
        "injectkit": "^1.5.0",
        "koa": "^3.2.1",
        "kysely": "^0.29.2",
        "luxon": "^3.7.2",
        "nodemailer": "^9.0.3",
        "pg": "^8.22.0",
        "pg-boss": "^12.24.0",
        "reflect-metadata": "^0.2.2",
        "yaml": "^2.8.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@repo/config-eslint": "workspace:*",
        "@repo/config-typescript": "workspace:*",
        "@swc-node/register": "^1.11.1",
        "@swc/core": "^1.15.43",
        "@types/koa": "^3.0.3",
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.0.1",
        "@types/nodemailer": "^8.0.1",
        "@types/pg": "^8.20.0",
        "dbmate": "^2.33.0",
        "kysely-codegen": "^0.20.0",
        "prettier": "^3.9.4",
        "typescript": "^6.0.3"
    }
}
