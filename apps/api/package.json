{
    "name": "@icloudsync/api",
    "private": true,
    "type": "module",
    "main": "index.ts",
    "scripts": {
        "dev": "node --inspect --no-warnings --no-deprecation --import @swc-node/register/esm-register --enable-source-maps --watch --watch-preserve-output ./src/index.ts",
        "build": "tsc",
        "seed:dev": "node --no-warnings --no-deprecation --import @swc-node/register/esm-register ./src/dev/seed.run.ts",
        "build:data": "pnpm migrate:up && pnpm build:datatypes",
        "rebuild:data": "pnpm migrate:down:all && pnpm build:data",
        "build:contracts": "contractkit",
        "build:datatypes": "kysely-codegen",
        "build:permissions": "pdsl",
        "migrate:up": "dbmate -d ./data/migrations up",
        "migrate:down": "dbmate -d ./data/migrations down",
        "migrate:down:all": "./scripts/rollbackall.sh",
        "migrate:create": "dbmate -d ./data/migrations new",
        "lint": "eslint --fix",
        "format": "prettier --write .",
        "test": "vitest run"
    },
    "dependencies": {
        "@koa/router": "^15.6.0",
        "@maroonedsoftware/appconfig": "^2.0.0",
        "@maroonedsoftware/authentication": "^4.28.0",
        "@maroonedsoftware/cache": "^0.1.9",
        "@maroonedsoftware/encryption": "^0.5.2",
        "@maroonedsoftware/errors": "^1.7.0",
        "@maroonedsoftware/jobbroker": "^1.5.0",
        "@maroonedsoftware/koa": "^2.4.4",
        "@maroonedsoftware/kysely": "^0.7.0",
        "@maroonedsoftware/logger": "^1.1.1",
        "@maroonedsoftware/multipart": "^1.2.1",
        "@maroonedsoftware/permissions": "^0.2.1",
        "@maroonedsoftware/policies": "^0.5.0",
        "@maroonedsoftware/utilities": "^1.10.0",
        "@maroonedsoftware/zod": "^0.4.2",
        "injectkit": "^1.5.0",
        "koa": "^3.2.1",
        "kysely": "^0.29.2",
        "luxon": "^3.7.2",
        "pg": "^8.22.0",
        "pg-boss": "^12.20.0",
        "rate-limiter-flexible": "^11.2.0",
        "raw-body": "^3.0.2",
        "reflect-metadata": "^0.2.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@contractkit/cli": "^0.10.2",
        "@contractkit/plugin-typescript": "^0.27.0",
        "@maroonedsoftware/permissions-dsl": "^0.4.1",
        "@repo/config-eslint": "workspace:*",
        "@repo/config-typescript": "workspace:*",
        "@swc-node/register": "^1.11.1",
        "@swc/core": "^1.15.43",
        "@types/jsdom": "^28.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/koa": "^3.0.3",
        "@types/koa__router": "^12.0.5",
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.0.0",
        "@types/pg": "^8.20.0",
        "dbmate": "^2.33.0",
        "kysely-codegen": "^0.20.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    }
}
